# Copy this file to .env and fill in your values
DATABASE_URL="postgresql://user:password@host:5432/amazon_clone?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/amazon_clone?sslmode=require"
PORT=5000
CORS_ORIGIN=http://localhost:5173,https://your-frontend.onrender.com
NODE_ENV=production

# SMTP (optional, for order confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Amazon Clone <your-email@gmail.com>"
